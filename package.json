{
  "name": "wp-epub-gen",
  "version": "0.6.0",
  "description": "Epub generator.",
  "type": "module",
  "main": "build/index.cjs",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "test": "vitest --watch=false run",
    "tt": "npm run build && node ./test/tt.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "build": "cross-env NODE_ENV=production vite build --config vite.config.ts",
    "bt": "npm run build && npm run test",
    "w": "tsc --noEmit -w",
    "p": "npm publish --access public",
    "prepublishOnly": "npm run build && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oldj/wp-epub-gen.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/oldj/wp-epub-gen/issues"
  },
  "homepage": "https://github.com/oldj/wp-epub-gen#readme",
  "files": [
    "build"
  ],
  "dependencies": {
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "diacritics": "^1.3.0",
    "ejs": "^5.0.2",
    "entities": "^8.0.0",
    "fs-extra": "^11.3.4",
    "mime": "^4.1.0",
    "superagent": "^10.3.0",
    "uslug": "^1.0.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^7.0.0",
    "@types/diacritics": "^1.3.3",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/superagent": "^8.1.9",
    "@types/uslug": "^1.0.4",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
