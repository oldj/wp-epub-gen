{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "allowJs": true,
    "sourceMap": true,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./build",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "test", "dist"]
}
